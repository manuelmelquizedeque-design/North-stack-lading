    <section id="como-funciona" class="section">
        <div class="container">
            <div class="section-header fade-in">
                <span class="section-tag lang-pt">Processo</span>
                <span class="section-tag lang-en">Process</span>
                <h2 class="section-title lang-pt">Como Funciona</h2>
                <h2 class="section-title lang-en">How it Works</h2>
            </div>
